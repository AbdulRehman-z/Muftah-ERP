me/abdul-rehman/Projects/titan-new/src/lib/authz.server.ts", "source_location": "L286", "weight": 1.0}, {"source": "lib_authz_server_syncuserroleassignment", "target": "lib_authz_server_ensurerbacseeded", "relation": "calls", "context": "call", "confidence": "EXTRACTED", "source_file": "/home/abdul-rehman/Projects/titan-new/src/lib/authz.server.ts", "source_location": "L319", "weight": 1.0}, {"source": "lib_authz_server_syncuserroleassignment", "target": "lib_authz_server_getrolebyslug", "relation": "calls", "context": "call", "confidence": "EXTRACTED", "source_file": "/home/abdul-rehman/Projects/titan-new/src/lib/authz.server.ts", "source_location": "L321", "weight": 1.0}], "raw_calls": [{"caller_nid": "lib_authz_server_upsertroleseed", "callee": "returning", "is_member_call": true, "source_file": "/home/abdul-rehman/Projects/titan-new/src/lib/authz.server.ts", "source_location": "L55"}, {"caller_nid": "lib_authz_server_upsertroleseed", "callee": "onConflictDoUpdate", "is_member_call": true, "source_file": "/home/abdul-rehman/Projects/titan-new/src/lib/authz.server.ts", "source_location": "L55"}, {"caller_nid": "lib_authz_server_upsertroleseed", "callee": "values", "is_member_call": true, "source_file": "/home/abdul-rehman/Projects/titan-new/src/lib/authz.server.ts", "source_location": "L55"}, {"caller_nid": "lib_authz_server_upsertroleseed", "callee": "insert", "is_member_call": true, "source_file": "/home/abdul-rehman/Projects/titan-new/src/lib/authz.server.ts", "source_location": "L55"}, {"caller_nid": "lib_authz_server_ensurerbacseeded", "callee": "catch", "is_member_call": true, "source_file": "/home/abdul-rehman/Projects/titan-new/src/lib/authz.server.ts", "source_location": "L81"}, {"caller_nid": "lib_authz_server_ensurerbacseeded", "callee": "(async () => {\n      await db.transaction(async (tx) => {\n        for (const permission of PERMISSION_DEFINITIONS) {\n          await tx\n            .insert(appPermissions)\n            .values({\n              key: permission.key,\n              moduleKey: permission.moduleKey,\n              label: permission.label,\n              description: permission.description,\n              kind: permission.kind,\n              routePattern: permission.routePattern ?? null,\n            })\n            .onConflictDoUpdate({\n              target: appPermissions.key,\n              set: {\n                moduleKey: permission.moduleKey,\n                label: permission.label,\n                description: permission.description,\n                kind: permission.kind,\n                routePattern: permission.routePattern ?? null,\n                updatedAt: new Date(),\n              },\n            });\n        }\n\n        const permissionRecords = await tx.query.appPermissions.findMany();\n        const permissionIdByKey = new Map(\n          permissionRecords.map((permission) => [permission.key, permission.id]),\n        );\n\n        for (const roleSeed of SYSTEM_ROLE_SEEDS) {\n          const roleRecord = await upsertRoleSeed(tx as typeof db, roleSeed);\n          const existingPermissionCount = await tx.query.appRolePermissions.findMany({\n            where: eq(appRolePermissions.roleId, roleRecord.id),\n            columns: {\n              roleId: true,\n            },\n          });\n\n          if (roleSeed.permissionKeys[0] === \"*\") {\n            continue;\n          }\n\n          if (existingPermissionCount.length > 0) {\n            continue;\n          }\n\n          const permissionIds = roleSeed.permissionKeys\n            .map((permissionKey) => permissionIdByKey.get(permissionKey))\n            .filter(Boolean) as string[];\n\n          if (permissionIds.length > 0) {\n            await tx.insert(appRolePermissions).values(\n              permissionIds.map((permissionId) => ({\n                roleId: roleRecord.id,\n                permissionId,\n              })),\n            );\n          }\n        }\n      });\n    })", "is_member_call": false, "source_file": "/home/abdul-rehman/Projects/titan-new/src/lib/authz.server.ts", "source_location": "L81"}, {"caller_nid": "lib_authz_server_getheaders", "callee": "getRequestHeaders", "is_member_call": false, "source_file": "/home/abdul-rehman/Projects/titan-new/src/lib/authz.server.ts", "source_location": "L153"}, {"caller_nid": "lib_authz_server_getsessionfromrequest", "callee": "getSession", "is_member_call": true, "source_file": "/home/abdul-rehman/Projects/titan-new/src/lib/authz.server.ts", "source_location": "L157"}, {"caller_nid": "lib_authz_server_getrolebyslug", "callee": "findFirst", "is_member_call": true, "source_file": "/home/abdul-rehman/Projects/titan-new/src/lib/authz.server.ts", "source_location": "L163"}, {"caller_nid": "lib_authz_server_getrolebyslug", "callee": "eq", "is_member_call": false, "source_file": "/home/abdul-rehman/Projects/titan-new/src/lib/authz.server.ts", "source_location": "L164"}, {"caller_nid": "lib_authz_server_resolveuserrole", "callee": "findFirst", "is_member_call": true, "source_file": "/home/abdul-rehman/Projects/titan-new/src/lib/authz.server.ts", "source_location": "L171"}, {"caller_nid": "lib_authz_server_resolveuserrole", "callee": "eq", "is_member_call": false, "source_file": "/home/abdul-rehman/Projects/titan-new/src/lib/authz.server.ts", "source_location": "L172"}, {"caller_nid": "lib_authz_server_resolveuserrole", "callee": "onConflictDoNothing", "is_member_call": true, "source_file": "/home/abdul-rehman/Projects/titan-new/src/lib/authz.server.ts", "source_location": "L190"}, {"caller_nid": "lib_authz_server_resolveuserrole", "callee": "values", "is_member_call": true, "source_file": "/home/abdul-rehman/Projects/titan-new/src/lib/authz.server.ts", "source_location": "L190"}, {"caller_nid": "lib_authz_server_resolveuserrole", "callee": "insert", "is_member_call": true, "source_file": "/home/abdul-rehman/Projects/titan-new/src/lib/authz.server.ts", "source_location": "L190"}, {"caller_nid": "lib_authz_server_getrolepermiss