# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/main
DATABASE_SSL=false
DB_POOL_MAX=10

# Better Auth
BETTER_AUTH_SECRET=replace-with-a-64-char-hex-secret
BETTER_AUTH_URL=http://localhost:3000

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@example.com
SMTP_PASS=replace-with-smtp-password
SMTP_FROM="Titan Enterprise" <noreply@example.com>

# App
NODE_ENV=development

# Super admin bootstrap (critical)
ADMIN_BOOTSTRAP_SECRET=replace-with-a-long-random-secret
ALLOW_PUBLIC_SIGNUP=false
